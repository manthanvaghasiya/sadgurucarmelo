# ──────────────────────────────────────────────
# Sadguru Car Melo — Backend Environment Config
# ──────────────────────────────────────────────

# Server
PORT=5000
NODE_ENV=development

# MongoDB
MONGO_URI=mongodb+srv://<USER>:<PASSWORD>@<CLUSTER>.mongodb.net/?appName=Cluster0

# JWT
JWT_SECRET=your_random_64_character_production_secret_key_here
JWT_EXPIRE=7d

# Cloudinary
CLOUDINARY_CLOUD_NAME=your_cloud_name
CLOUDINARY_API_KEY=your_api_key
CLOUDINARY_API_SECRET=your_api_secret

# Google Places API
GOOGLE_PLACE_ID=your_place_id
GOOGLE_PLACES_API_KEY=YOUR_GOOGLE_PLACES_API_KEY_HERE

# CORS — Frontend URL (used for production CORS origin)
FRONTEND_URL=https://sadgurucarsurat.com

# Webhook — n8n / automation (optional, for lead forwarding)
N8N_WEBHOOK_URL=https://your-n8n-instance.com/webhook/xxx
